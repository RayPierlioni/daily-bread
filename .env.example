# Local development uses SQLite. Production should use the Supabase/Postgres URL from .env.production.example.
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth is optional for local review. The demo sign-in remains available without these.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: when set, Ask in Faith calls the OpenAI Responses API.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
