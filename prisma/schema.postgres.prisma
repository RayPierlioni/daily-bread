generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum DevotionalStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PrayerStatus {
  ONGOING
  ANSWERED
  WAITING
  PRAISE_REPORT
}

enum PrivacyLevel {
  PRIVATE
  GROUP
  ANONYMOUS
}

enum PostType {
  PRAYER_REQUEST
  PRAISE_REPORT
  REFLECTION
  QUESTION
  TESTIMONY
  BLOG
  DEVOTIONAL_DISCUSSION
  GROUP_ANNOUNCEMENT
}

enum Visibility {
  PUBLIC
  GROUP
  PRIVATE
}

enum GroupPrivacy {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum GroupRole {
  MEMBER
  LEADER
  ADMIN
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

enum SourceCategory {
  SCRIPTURE
  THEOLOGY
  CHURCH_HISTORY
  ARCHAEOLOGY
  APOLOGETICS
  PASTORAL
}

model User {
  id                     String                @id @default(cuid())
  name                   String?
  email                  String?               @unique
  emailVerified          DateTime?
  image                  String?
  bio                    String?
  church                 String?
  denomination           String?
  role                   Role                  @default(USER)
  spiritualFocusProfile  String?
  onboardingCompleted    Boolean               @default(false)
  privacySettings        Json?
  notificationSettings   Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  accounts               Account[]
  sessions               Session[]
  spiritualAssessments   SpiritualAssessment[]
  devotionals            UserDevotional[]
  devotionalProgress     UserDevotionalProgress?
  createdDevotionals     Devotional[]          @relation("CreatedDevotionals")
  faithQuestions         FaithQuestion[]
  prayers                Prayer[]
  posts                  Post[]
  comments               Comment[]
  createdGroups          PrayerGroup[]         @relation("CreatedGroups")
  groupMemberships       GroupMember[]
  blogs                  Blog[]
  blogComments           BlogComment[]
  reportsMade            Report[]              @relation("ReportsMade")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SpiritualAssessment {
  id                String   @id @default(cuid())
  userId            String
  answers           Json
  generatedProfile  String
  recommendedTopics Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Devotional {
  id                       String             @id @default(cuid())
  title                    String
  date                     DateTime           @unique
  scriptureReference       String
  scriptureText            String
  body                     String
  reflectionQuestion       String
  prayerPrompt             String
  actionStep               String
  tags                     Json
  spiritualFocusCategories Json
  status                   DevotionalStatus   @default(DRAFT)
  createdBy                String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  creator                  User?              @relation("CreatedDevotionals", fields: [createdBy], references: [id], onDelete: SetNull)
  userDevotionals          UserDevotional[]
  trackItems               DevotionalTrackItem[]
}

model DevotionalTrack {
  id             String                    @id @default(cuid())
  title          String
  slug           String                    @unique
  description    String
  focusCategory  String
  startingLevel  String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  items          DevotionalTrackItem[]
  userProgress   UserDevotionalProgress[]
}

model DevotionalTrackItem {
  id            String           @id @default(cuid())
  trackId       String
  devotionalId  String
  sequence      Int
  createdAt     DateTime         @default(now())

  track         DevotionalTrack  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  devotional    Devotional       @relation(fields: [devotionalId], references: [id], onDelete: Cascade)

  @@unique([trackId, sequence])
  @@unique([trackId, devotionalId])
}

model UserDevotionalProgress {
  id               String           @id @default(cuid())
  userId           String           @unique
  trackId          String
  currentSequence  Int              @default(1)
  startedAt        DateTime         @default(now())
  lastAdvancedAt   DateTime?
  completedTrackAt DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  track            DevotionalTrack  @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model UserDevotional {
  id            String      @id @default(cuid())
  userId        String
  devotionalId  String
  completed     Boolean     @default(false)
  saved         Boolean     @default(false)
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  devotional    Devotional  @relation(fields: [devotionalId], references: [id], onDelete: Cascade)

  @@unique([userId, devotionalId])
}

model FaithQuestion {
  id        String   @id @default(cuid())
  userId    String
  question  String
  aiAnswer  String
  sources   Json
  tags      Json
  saved     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prayer {
  id             String        @id @default(cuid())
  userId         String
  title          String
  text           String
  audioUrl       String?
  transcript     String?
  tags           Json
  mood           String?
  relatedVerse   String?
  status         PrayerStatus  @default(ONGOING)
  privacyLevel   PrivacyLevel  @default(PRIVATE)
  sharedGroupId  String?
  followUpNotes  String?
  answeredAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedGroup    PrayerGroup?  @relation(fields: [sharedGroupId], references: [id], onDelete: SetNull)
}

model Post {
  id         String       @id @default(cuid())
  userId     String
  type       PostType
  title      String
  body       String
  mediaUrl   String?
  tags       Json
  groupId    String?
  visibility Visibility   @default(PUBLIC)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      PrayerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  comments   Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrayerGroup {
  id          String        @id @default(cuid())
  name        String
  description String
  creatorId   String
  privacy     GroupPrivacy  @default(PUBLIC)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator     User          @relation("CreatedGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  posts       Post[]
  prayers     Prayer[]
}

model GroupMember {
  id        String      @id @default(cuid())
  groupId   String
  userId    String
  role      GroupRole   @default(MEMBER)
  createdAt DateTime    @default(now())

  group     PrayerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Blog {
  id          String        @id @default(cuid())
  authorId    String
  title       String
  body        String
  coverImage  String?
  tags        Json
  status      BlogStatus    @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    BlogComment[]
}

model BlogComment {
  id        String   @id @default(cuid())
  blogId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  contentType String
  contentId   String
  reason      String
  status      ReportStatus @default(OPEN)
  adminNotes  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter    User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
}

model SourceLibraryItem {
  id                  String         @id @default(cuid())
  title               String
  category            SourceCategory
  summary             String
  content             String
  scriptureReferences Json
  externalReference   String?
  tags                Json
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}
