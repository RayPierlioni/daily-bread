{
  "name": "daily-bread-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/prisma-generate.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src prisma next.config.ts",
    "typecheck": "tsc --noEmit",
    "deploy:check": "node scripts/deployment-check.mjs",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.prisma",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "node scripts/prisma-generate.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/client": "6.16.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "1.14.0",
    "next": "16.2.4",
    "next-auth": "4.24.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.69.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "prisma": "6.16.3",
    "tailwindcss": "4.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
